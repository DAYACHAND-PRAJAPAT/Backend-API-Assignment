<mxfile host="app.diagrams.net">
  <diagram name="Architecture" id="arch1">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Client -->
        <mxCell id="client" value="Client / Postman" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="440" y="20" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Docker container boundary -->
        <mxCell id="dockerBox" value="DOCKER NETWORK CONTAINER" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#666666;fontStyle=1;align=left;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="120" width="860" height="640" as="geometry" />
        </mxCell>

        <!-- FastAPI -->
        <mxCell id="fastapi" value="FastAPI (web)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="440" y="170" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- PostgreSQL -->
        <mxCell id="postgres" value="PostgreSQL (db)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="250" y="300" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Redis -->
        <mxCell id="redis" value="Redis (broker)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="650" y="300" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Celery Pool boundary -->
        <mxCell id="celeryBox" value="Celery Pool (worker)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#666666;fontStyle=1;align=left;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="420" width="650" height="160" as="geometry" />
        </mxCell>

        <!-- Data Cleaner -->
        <mxCell id="cleaner" value="4a. Data Cleaner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="250" y="480" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Anomaly Detector -->
        <mxCell id="anomaly" value="4b. Anomaly Detection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="570" y="480" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Gemini API -->
        <mxCell id="gemini" value="Gemini 1.5 Flash API&#10;(External LLM Layer)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="600" y="800" width="240" height="70" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" value="1. POST /jobs/upload (CSV File)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="client" target="fastapi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e2" value="2. Write 'pending' Job State" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="fastapi" target="postgres">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e3" value="3. Dispatch Raw File Bytes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="fastapi" target="redis">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e4" value="4. Consume Task" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="redis" target="anomaly">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="cleaner" target="anomaly">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e6" value="6. Sync Completed Data &amp; Summary" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="celeryBox" target="postgres">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e7" value="5. Single Batch Turn Request (google-genai SDK)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="anomaly" target="gemini">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
